{
  "name": "sma-erp",
  "version": "8.3.0",
  "description": "SMA ERP Server Software",
  "author": "JFT Agro",
  "private": true,
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pack-pc": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-static-copy": "^4.0.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "chart.js": "^4.5.1",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "firebase": "^12.10.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "leaflet": "^1.9.4",
    "lucide": "^0.577.0",
    "nanoid": "^5.1.6",
    "pptxgenjs": "^4.0.1",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.sma.erp",
    "productName": "SMA ERP",
    "directories": {
      "output": "SMA-ERP-PRODUCTION/"
    },
    "files": [
      "index.html",
      "assets/**/*",
      "views/**/*",
      "electron.cjs",
      "preload.cjs",
      "package.json",
      "manifest.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
